# Block commits to protected branches
branch=$(git branch --show-current)
case "$branch" in
  main|master|production|beads-sync)
    echo "BLOCKED: Cannot commit directly to '$branch'. Use a feature branch."
    exit 1
    ;;
esac

# Block committing local-only artifacts (traces/, plans/, root session reports, etc.)
./scripts/check-artifacts.sh --staged

# Check for cyclic dependencies before commit
pnpm check:cycles

# Lint check
pnpm check:lint
