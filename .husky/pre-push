#!/usr/bin/env sh

# Block pushes to protected branches
branch=$(git branch --show-current)
case "$branch" in
  main|master|production|beads-sync)
    echo ""
    echo "BLOCKED: Direct push to protected branch '$branch'."
    echo "Use a feature branch and PR."
    echo ""
    exit 1
    ;;
esac

# Block force pushes (check for --force or -f in the push command)
# Git passes the remote and URL as arguments
# We can't easily detect --force here, but we block the dangerous branches above

# Block pushes with untracked source files
# Catches the failure mode where subagents create files but don't commit them.
untracked=$(git ls-files --others --exclude-standard -- \
  'src/**/*.ts' 'src/**/*.js' \
  'cli/src/**/*.ts' 'cli/src/**/*.js' \
  'supabase/**/*.sql' \
  2>/dev/null)
if [ -n "$untracked" ]; then
  echo ""
  echo "BLOCKED: Untracked source files found. Commit or remove before pushing:"
  echo "$untracked" | head -20
  echo ""
  exit 1
fi
